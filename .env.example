# ============================================================
# Warmr — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── INBOXES ──────────────────────────────────────────────────────────────────
# Add one block per sending inbox. Increment the number for each new one.
# These are your client sending domains — not the warmup network accounts.

INBOX_1_EMAIL=outreach@yourdomain.nl
INBOX_1_PASSWORD=your-app-password-here
INBOX_1_PROVIDER=google
INBOX_1_DOMAIN=yourdomain.nl

# INBOX_2_EMAIL=info@yourdomain.nl
# INBOX_2_PASSWORD=your-app-password-here
# INBOX_2_PROVIDER=google
# INBOX_2_DOMAIN=yourdomain.nl

# ── WARMUP NETWORK ────────────────────────────────────────────────────────────
# Gmail accounts that act as fake recipients in the warmup network.
# These are NOT sending domains — they only receive and reply.
# Aim for 20–30 accounts for a realistic engagement pattern.
# Each account needs an app-specific password (2FA must be enabled on the Gmail account).

WARMUP_NETWORK_1_EMAIL=warmupaccount1@gmail.com
WARMUP_NETWORK_1_PASSWORD=your-app-password-here

WARMUP_NETWORK_2_EMAIL=warmupaccount2@gmail.com
WARMUP_NETWORK_2_PASSWORD=your-app-password-here

# ... continue pattern up to WARMUP_NETWORK_30_*

# ── SUPABASE ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── ANTHROPIC ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE

# ── API / SECURITY ────────────────────────────────────────────────────────────
WARMR_API_TOKEN=generate-a-random-string-here
WARMR_MASTER_KEY=generate-a-long-random-string-for-encrypting-smtp-passwords
WARMR_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:5500,http://localhost:3000

# ── DAILY BRIEFING ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
BRIEFING_FROM_EMAIL=briefing@yourdomain.nl

# ── WARMUP SETTINGS ───────────────────────────────────────────────────────────
WARMUP_LANGUAGE=nl
TARGET_MARKET=BENELUX
REPLY_RATE=0.35
MAX_DAILY_WARMUP=80
DAILY_API_BUDGET_EUR=2.00

# ── SEND WINDOW ───────────────────────────────────────────────────────────────
SEND_WINDOW_START=07:00
SEND_WINDOW_END=19:00
SEND_DAYS=1,2,3,4,5
